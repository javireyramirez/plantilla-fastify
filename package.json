{
  "name": "plantilla-fastify",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:all": "concurrently \"pnpm dev\" \"pnpm --filter @repo/emails dev\"",
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "pnpm db:generate && rimraf dist && tsc && tsc-alias",
    "start": "node --env-file=.env dist/server.js",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"**/*.{ts,js,json,md,prisma}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md,prisma}\"",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx --env-file=.env prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1019.0",
    "@aws-sdk/s3-request-presigner": "^3.1019.0",
    "@better-auth/i18n": "^1.6.8",
    "@fastify/autoload": "^6.0.0",
    "@fastify/cors": "^10.1.0",
    "@fastify/env": "^5.0.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^9.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.0.0",
    "@fastify/swagger-ui": "^5.0.0",
    "@fastify/type-provider-typebox": "^5.0.0",
    "@fastify/under-pressure": "^9.0.0",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@react-email/components": "1.0.6",
    "@react-email/render": "^2.0.4",
    "@sinclair/typebox": "^0.34.0",
    "archiver": "^8.0.0",
    "better-auth": "^1.4.17",
    "bullmq": "^5.70.1",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^6.1.0",
    "fflate": "^0.8.2",
    "ioredis": "^5.10.0",
    "nanoid": "^5.1.6",
    "pg": "^8.17.2",
    "pino": "^10.3.0",
    "pino-pretty": "^13.1.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "resend": "^6.8.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/archiver": "^7.0.0",
    "@types/node": "^25.0.10",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "@vercel/node": "^5.5.27",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "prettier-plugin-prisma": "^5.0.0",
    "prisma": "^7.3.0",
    "rimraf": "^6.1.2",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=8"
  }
}
