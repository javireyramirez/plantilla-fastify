datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum RecordStatus {
  ACTIVE
  PENDING
  TRASHED
  INACTIVE
  ARCHIVED
  SUSPENDED
}

// ==========================================
// AUTHENTICATION & USERS
// ==========================================

model User {
  id            String   @id @default(uuid(7))
  email         String?  @unique
  password      String?
  name          String?
  image         String?
  emailVerified Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  isSystem      Boolean  @default(false)

  // Auditoría y Propiedad: Documentos
  createdDocuments  Document[] @relation("CreatedDocuments")
  deletedDocuments  Document[] @relation("DeletedDocuments")
  restoredDocuments Document[] @relation("RestoredDocuments")
  updatedDocuments  Document[] @relation("UpdatedDocuments")
  ownedDocuments    Document[] @relation("UserOwnedDocuments")

  // Auditoría y Propiedad: Compañías
  createdCompanies  Company[] @relation("CreatedCompanies")
  deletedCompanies  Company[] @relation("DeletedCompanies")
  restoredCompanies Company[] @relation("RestoredCompanies")
  updatedCompanies  Company[] @relation("UpdatedCompanies")
  ownedCompanies    Company[] @relation("UserOwnedCompanies")

  // Auditoría y Propiedad: Organizaciones
  createdOrganizations  Organization[] @relation("CreatedOrganizations")
  deletedOrganizations  Organization[] @relation("DeletedOrganizations")
  restoredOrganizations Organization[] @relation("RestoredOrganizations")
  updatedOrganizations  Organization[] @relation("UpdatedOrganizations")
  ownedOrganizations    Organization[] @relation("UserOwnedOrganizations")

  invitedMembers OrganizationMember[] @relation("InvitedMembers")

  // Auditoría y Propiedad: Roles
  createdRoles  Role[] @relation("CreatedRoles")
  deletedRoles  Role[] @relation("DeletedRoles")
  restoredRoles Role[] @relation("RestoredRoles")
  updatedRoles  Role[] @relation("UpdatedRoles")
  ownedRoles    Role[] @relation("UserOwnedRoles")

  grantedRolePermissions RolePermission[] @relation("GrantedRolePermissions")
  updatedRolePermissions RolePermission[] @relation("UpdatedRolePermissions")

  // Auditoría y Propiedad: Teams
  createdTeams  Team[] @relation("CreatedTeams")
  deletedTeams  Team[] @relation("DeletedTeams")
  restoredTeams Team[] @relation("RestoredTeams")
  updatedTeams  Team[] @relation("UpdatedTeams")
  userOwnedTeam Team[] @relation("UserOwnedTeam")

  invitedTeamMembers TeamMember[] @relation("InvitedTeamMembers")

  // Auth Auxiliar
  accounts  Account[]
  sessions  Session[]
  keys      Key[]
  emailLogs EmailLog[]

  // Acceso y Membresía
  memberships   OrganizationMember[]
  grantedAccess EntityAccess[]       @relation("GrantedAccess")
  revokedAccess EntityAccess[]       @relation("RevokedAccess")

  // Asignaciones de roles
  roleAssignments    RoleAssignment[] @relation("UserAssignments")
  grantedAssignments RoleAssignment[] @relation("GrantedAssignments")
  // rolePermissionAuditLogs RolePermissionAuditLog[]

  //Modules
  createdModule   Module[] @relation("CreatedModule")
  deletedModule   Module[] @relation("DeletedModule")
  restoredModule  Module[] @relation("RestoredModule")
  updatedModule   Module[] @relation("UpdatedModule")
  userOwnedModule Module[] @relation("UserOwnedModule")

  @@index([email])
  @@index([isActive])
  @@map("auth_users")
}

model Account {
  id                    String    @id @default(uuid(7))
  userId                String
  providerId            String
  accountId             String
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  idToken               String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("auth_accounts")
}

model Session {
  id        String   @id @default(uuid(7))
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?  @db.Text
  isValid   Boolean  @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([token])
  @@index([isValid])
  @@map("auth_sessions")
}

model VerificationToken {
  id         String   @id @default(uuid(7))
  identifier String
  token      String   @unique
  expires    DateTime
  used       Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@unique([identifier, token])
  @@index([expires])
  @@index([used])
  @@map("auth_verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(uuid(7))
  email     String
  token     String   @unique
  expires   DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
  @@index([expires])
  @@index([used])
  @@map("auth_password_reset_tokens")
}

model EmailVerificationCode {
  id        String   @id @default(uuid(7))
  email     String
  code      String
  expires   DateTime
  attempts  Int      @default(0)
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([code])
  @@index([expires])
  @@index([used])
  @@map("auth_email_verification_codes")
}

model Verification {
  id         String    @id @default(uuid(7))
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("auth_verification")
}

model Key {
  id         String    @id @default(uuid(7))
  userId     String
  name       String?
  secret     String
  lastUsedAt DateTime?
  expiresAt  DateTime?
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
  @@map("auth_keys")
}

model LoginAttempt {
  id         String   @id @default(uuid(7))
  email      String
  success    Boolean
  ipAddress  String?
  userAgent  String?  @db.Text
  failReason String?
  createdAt  DateTime @default(now())

  @@index([email])
  @@index([createdAt])
  @@index([success])
  @@map("auth_login_attempts")
}

// ==========================================
// COMMUNICATIONS
// ==========================================

enum EmailType {
  PASSWORD_RESET
  EMAIL_VERIFICATION
  WELCOME
  NOTIFICATION
  MARKETING
}

enum EmailStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
  BOUNCED
}

model EmailLog {
  id         String      @id @default(uuid(7))
  userId     String?
  recipient  String
  subject    String
  body       String      @db.Text
  type       String
  status     EmailStatus
  provider   String      @default("resend")
  providerId String?     @unique

  templateId String?
  metadata   Json?

  error String? @db.Text

  sentAt    DateTime?
  openedAt  DateTime?
  clickedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([providerId])
  @@index([status])
  @@index([createdAt])
  @@map("email_log")
}

// ==========================================
// CORE ENTITIES & AUDIT PATTERNS
// ==========================================

model Document {
  id String @id @default(uuid(7))

  // Archivo
  fileName    String
  fileKey     String @unique
  contentType String
  size        Int

  status RecordStatus @default(PENDING)

  checksum String?
  metadata Json?

  entityType String
  entityId   String

  // Auditoría
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  restoreAt DateTime?

  createdBy String?
  creator   User?   @relation("CreatedDocuments", fields: [createdBy], references: [id], onDelete: SetNull)

  deletedBy String?
  deletor   User?   @relation("DeletedDocuments", fields: [deletedBy], references: [id], onDelete: SetNull)

  restoreBy String?
  restorer  User?   @relation("RestoredDocuments", fields: [restoreBy], references: [id], onDelete: SetNull)

  updatedBy String?
  updater   User?   @relation("UpdatedDocuments", fields: [updatedBy], references: [id], onDelete: SetNull)

  // Propiedad (RBAC)
  ownerId             String?
  ownerTeamId         String?
  ownerOrganizationId String?

  owner             User?         @relation("UserOwnedDocuments", fields: [ownerId], references: [id], onDelete: SetNull)
  ownerTeam         Team?         @relation("TeamOwnedDocuments", fields: [ownerTeamId], references: [id], onDelete: SetNull)
  ownerOrganization Organization? @relation("OrgOwnedDocuments", fields: [ownerOrganizationId], references: [id], onDelete: SetNull)

  // Visibilidad
  isPublic Boolean @default(false)

  @@index([entityId, entityType, status])
  @@index([fileName])
  @@index([createdAt])
  @@index([ownerId])
  @@index([ownerTeamId])
  @@index([ownerOrganizationId])
  @@map("document")
}

// ==========================================
// RBAC: MÓDULOS
// ==========================================
//
// Catálogo de módulos disponibles en la aplicación.
// Es la fuente de verdad para las filas de la matriz de permisos.
// Se registran en código (seed) y se consultan en la UI.
//
// Ejemplos de keys: "crm", "invoices", "users", "reports", "settings"

model Module {
  id                 String       @id @default(uuid(7))
  key                String       @unique
  label              String
  description        String?
  icon               String?
  isActive           Boolean      @default(true)
  sortOrder          Int          @default(0)
  defaultPermissions Json?
  status             RecordStatus @default(ACTIVE)

  isConfigurableByOrg Boolean @default(true)

  // Auditoría
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  restoreAt DateTime?

  createdBy String?
  creator   User?   @relation("CreatedModule", fields: [createdBy], references: [id], onDelete: SetNull)

  deletedBy String?
  deletor   User?   @relation("DeletedModule", fields: [deletedBy], references: [id], onDelete: SetNull)

  restoreBy String?
  restorer  User?   @relation("RestoredModule", fields: [restoreBy], references: [id], onDelete: SetNull)

  updatedBy String?
  updater   User?   @relation("UpdatedModule", fields: [updatedBy], references: [id], onDelete: SetNull)

  // Propiedad (RBAC sobre el propio rol)
  ownerId             String?
  ownerTeamId         String?
  ownerOrganizationId String?

  owner             User?         @relation("UserOwnedModule", fields: [ownerId], references: [id], onDelete: SetNull)
  ownerTeam         Team?         @relation("TeamOwnedModule", fields: [ownerTeamId], references: [id], onDelete: SetNull)
  ownerOrganization Organization? @relation("OrgOwnedModule", fields: [ownerOrganizationId], references: [id], onDelete: SetNull)

  permissions RolePermission[]
  // rolePermissionAuditLogs RolePermissionAuditLog[]

  @@map("rbac_modules")
}

// ==========================================
// RBAC: ROLES Y PERMISOS
// ==========================================

model Role {
  id          String  @id @default(uuid(7))
  name        String
  slug        String  @unique
  description String?
  color       String?
  icon        String?
  isSystem    Boolean @default(false)

  status RecordStatus @default(ACTIVE)

  // Auditoría
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  restoreAt DateTime?

  createdBy String?
  creator   User?   @relation("CreatedRoles", fields: [createdBy], references: [id], onDelete: SetNull)

  deletedBy String?
  deletor   User?   @relation("DeletedRoles", fields: [deletedBy], references: [id], onDelete: SetNull)

  restoreBy String?
  restorer  User?   @relation("RestoredRoles", fields: [restoreBy], references: [id], onDelete: SetNull)

  updatedBy String?
  updater   User?   @relation("UpdatedRoles", fields: [updatedBy], references: [id], onDelete: SetNull)

  // Propiedad (RBAC sobre el propio rol)
  ownerId             String?
  ownerTeamId         String?
  ownerOrganizationId String?

  owner             User?         @relation("UserOwnedRoles", fields: [ownerId], references: [id], onDelete: SetNull)
  ownerTeam         Team?         @relation("TeamOwnedRoles", fields: [ownerTeamId], references: [id], onDelete: SetNull)
  ownerOrganization Organization? @relation("OrgOwnedRoles", fields: [ownerOrganizationId], references: [id], onDelete: SetNull)

  // Relaciones estructurales
  permissions     RolePermission[]
  roleAssignments RoleAssignment[]
  // rolePermissionAuditLogs RolePermissionAuditLog[]

  @@map("rbac_roles")
}

// Scope de un permiso: define SOBRE QUÉ REGISTROS aplica la acción.
//
//   GLOBAL       → todos los registros del sistema (antes ALL)
//   ORGANIZATION → registros de la propia organización
//   TEAM         → registros del propio team
//   OWN          → solo los registros creados/poseídos por el usuario
//
// El check de permisos toma el scope MÁS PERMISIVO entre todos
// los roles asignados al usuario en ese contexto.
// Orden de precedencia: GLOBAL > ORGANIZATION > TEAM > OWN

enum PermissionScope {
  GLOBAL
  ORGANIZATION
  TEAM
  OWN
}

enum PermissionAction {
  READ
  CREATE
  UPDATE
  DELETE
  RESTORE
  EXPORT
  IMPORT
  SETTINGS
}

// Permisos definidos por rol y módulo.
// Un rol puede tener un permiso por combinación (moduleId, action).
// El scope indica hasta dónde llega ese permiso.

model RolePermission {
  id       String           @id @default(uuid(7))
  roleId   String
  moduleId String
  action   PermissionAction
  scope    PermissionScope  @default(OWN)

  grantedAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  grantedBy String?
  granter   User?   @relation("GrantedRolePermissions", fields: [grantedBy], references: [id], onDelete: SetNull)
  updatedBy String?
  updater   User?   @relation("UpdatedRolePermissions", fields: [updatedBy], references: [id], onDelete: SetNull)

  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([roleId, moduleId, action])
  @@index([roleId])
  @@index([moduleId])
  @@map("rbac_role_permissions")
}

enum PrincipalType {
  USER
  TEAM
  ORGANIZATION
}

// Asignación de roles a cualquier principal (usuario, team u org)
// con contexto de organización opcional.
//
// organizationId = null  → rol global (aplica en cualquier org)
// organizationId = <id>  → rol restringido a esa organización
//
// Un mismo usuario puede tener múltiples roles en la misma org
// (múltiples filas con el mismo userId y organizationId).
//
// Herencia de permisos en runtime:
//   1. Roles directos del usuario en la org
//   2. Roles asignados al team del usuario en la org
//   3. Roles asignados a la org completa
//   → se toma el scope más permisivo entre todos

model RoleAssignment {
  id     String @id @default(uuid(7))
  roleId String

  userId      String?
  teamId      String?
  targetOrgId String?

  organizationId String?

  assignedAt DateTime @default(now())
  assignedBy String?

  role         Role          @relation(fields: [roleId], references: [id], onDelete: Cascade)
  organization Organization? @relation("OrganizationRoleContext", fields: [organizationId], references: [id], onDelete: Cascade)
  granter      User?         @relation("GrantedAssignments", fields: [assignedBy], references: [id], onDelete: SetNull)

  assignedUser User?         @relation("UserAssignments", fields: [userId], references: [id], onDelete: Cascade)
  assignedTeam Team?         @relation("TeamAssignments", fields: [teamId], references: [id], onDelete: Cascade)
  assignedOrg  Organization? @relation("OrgAssignments", fields: [targetOrgId], references: [id], onDelete: Cascade)

  @@unique([roleId, userId, organizationId])
  @@unique([roleId, teamId, organizationId])
  @@unique([roleId, targetOrgId, organizationId])
  @@index([userId])
  @@index([teamId])
  @@index([targetOrgId])
  @@index([organizationId])
  @@map("rbac_role_assignments")
}

// ==========================================
// ORGANIZATION, TEAMS & MEMBERS
// ==========================================

model Organization {
  id        String       @id @default(uuid(7))
  name      String
  slug      String       @unique
  image     String?
  status    RecordStatus @default(ACTIVE)
  byDefault Boolean      @default(false)

  // Auditoría
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  restoreAt DateTime?

  createdBy String?
  creator   User?   @relation("CreatedOrganizations", fields: [createdBy], references: [id], onDelete: SetNull)

  deletedBy String?
  deletor   User?   @relation("DeletedOrganizations", fields: [deletedBy], references: [id], onDelete: SetNull)

  restoreBy String?
  restorer  User?   @relation("RestoredOrganizations", fields: [restoreBy], references: [id], onDelete: SetNull)

  updatedBy String?
  updater   User?   @relation("UpdatedOrganizations", fields: [updatedBy], references: [id], onDelete: SetNull)

  // Propiedad (soporte para sub-organizaciones)
  ownerId             String?
  ownerTeamId         String?
  ownerOrganizationId String?

  owner             User?         @relation("UserOwnedOrganizations", fields: [ownerId], references: [id], onDelete: SetNull)
  ownerTeam         Team?         @relation("TeamOwnedOrganizations", fields: [ownerTeamId], references: [id], onDelete: SetNull)
  ownerOrganization Organization? @relation("OrgOwnedOrganizations", fields: [ownerOrganizationId], references: [id], onDelete: SetNull)

  // Relaciones estructurales
  members        OrganizationMember[]
  teams          Team[]
  orgAssignments RoleAssignment[]     @relation("OrgAssignments")

  // Elementos que posee esta organización (reverse RBAC)
  ownedDocuments     Document[]     @relation("OrgOwnedDocuments")
  ownedCompanies     Company[]      @relation("OrgOwnedCompanies")
  ownedRoles         Role[]         @relation("OrgOwnedRoles")
  ownedOrganizations Organization[] @relation("OrgOwnedOrganizations")
  orgOwnedTeam       Team[]         @relation("OrgOwnedTeam")

  organizationRoleContext RoleAssignment[] @relation("OrganizationRoleContext")
  orgOwnedModule          Module[]         @relation("OrgOwnedModule")

  @@index([slug])
  @@map("org_organizations")
}

model OrganizationMember {
  id             String   @id @default(uuid(7))
  userId         String
  organizationId String
  isActive       Boolean  @default(true)
  joinedAt       DateTime @default(now())
  updatedAt      DateTime @updatedAt

  invitedBy String?
  inviter   User?   @relation("InvitedMembers", fields: [invitedBy], references: [id], onDelete: SetNull)

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  teamMembers  TeamMember[]

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
  @@map("org_members")
}

model Team {
  id             String       @id @default(uuid(7))
  organizationId String
  name           String
  description    String?
  status         RecordStatus @default(ACTIVE)

  // Auditoría
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  restoreAt DateTime?

  createdBy String?
  creator   User?   @relation("CreatedTeams", fields: [createdBy], references: [id], onDelete: SetNull)

  deletedBy String?
  deletor   User?   @relation("DeletedTeams", fields: [deletedBy], references: [id], onDelete: SetNull)

  restoreBy String?
  restorer  User?   @relation("RestoredTeams", fields: [restoreBy], references: [id], onDelete: SetNull)

  updatedBy String?
  updater   User?   @relation("UpdatedTeams", fields: [updatedBy], references: [id], onDelete: SetNull)

  // Relaciones
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members      TeamMember[]

  // Elementos que posee este team
  ownedDocuments     Document[]       @relation("TeamOwnedDocuments")
  ownedCompanies     Company[]        @relation("TeamOwnedCompanies")
  ownedRoles         Role[]           @relation("TeamOwnedRoles")
  ownedOrganizations Organization[]   @relation("TeamOwnedOrganizations")
  roleAssignments    RoleAssignment[] @relation("TeamAssignments")
  teamOwnedTeam      Team[]           @relation("TeamOwnedTeam")

  // Propiedad (RBAC)
  ownerId             String?
  ownerTeamId         String?
  ownerOrganizationId String?

  owner             User?         @relation("UserOwnedTeam", fields: [ownerId], references: [id], onDelete: SetNull)
  ownerTeam         Team?         @relation("TeamOwnedTeam", fields: [ownerTeamId], references: [id], onDelete: SetNull)
  ownerOrganization Organization? @relation("OrgOwnedTeam", fields: [ownerOrganizationId], references: [id], onDelete: SetNull)
  teamOwnedModule   Module[]      @relation("TeamOwnedModule")

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("org_teams")
}

model TeamMember {
  id       String @id @default(uuid(7))
  teamId   String
  memberId String // FK a OrganizationMember

  joinedAt DateTime @default(now())

  invitedBy String?
  inviter   User?   @relation("InvitedTeamMembers", fields: [invitedBy], references: [id], onDelete: SetNull)

  team   Team               @relation(fields: [teamId], references: [id], onDelete: Cascade)
  member OrganizationMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([teamId, memberId])
  @@index([teamId])
  @@index([memberId])
  @@map("org_team_members")
}

