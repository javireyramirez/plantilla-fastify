datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

//Auth
model User {
  id            String   @id @default(cuid())
  email         String?  @unique
  password      String?
  name          String?
  image         String?
  role          String?  @default("user")
  emailVerified Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  createdDocuments  Document[] @relation("CreatedDocuments")
  deletedDocuments  Document[] @relation("DeletedDocuments")
  restoredDocuments Document[] @relation("RestoredDocuments")
  updatedDocuments  Document[] @relation("UpdatedDocuments")
  ownedDocuments    Document[] @relation("OwnedDocuments")

  createdCompanies  Company[] @relation("CreatedCompanies")
  deletedCompanies  Company[] @relation("DeletedCompanies")
  restoredCompanies Company[] @relation("RestoredCompanies")
  updatedCompanies  Company[] @relation("UpdatedCompanies")
  ownedCompanies    Company[] @relation("OwnedCompanies")

  accounts  Account[]
  sessions  Session[]
  keys      Key[]
  emailLogs EmailLog[]

  memberships   OrganizationMember[]
  entityAccess  EntityAccess[]
  grantedAccess EntityAccess[]       @relation("GrantedAccess")

  @@index([email])
  @@index([isActive])
  @@map("auth_users")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  providerId            String
  accountId             String
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  idToken               String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("auth_accounts")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?  @db.Text
  isValid   Boolean  @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([token])
  @@index([isValid])
  @@map("auth_sessions")
}

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String
  token      String   @unique
  expires    DateTime
  used       Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@unique([identifier, token])
  @@index([expires])
  @@index([used])
  @@map("auth_verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
  @@index([expires])
  @@index([used])
  @@map("auth_password_reset_tokens")
}

model EmailVerificationCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  expires   DateTime
  attempts  Int      @default(0)
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([code])
  @@index([expires])
  @@index([used])
  @@map("auth_email_verification_codes")
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("auth_verification")
}

model Key {
  id         String    @id @default(cuid())
  userId     String
  name       String?
  secret     String
  lastUsedAt DateTime?
  expiresAt  DateTime?
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
  @@map("auth_keys")
}

model LoginAttempt {
  id         String   @id @default(cuid())
  email      String
  success    Boolean
  ipAddress  String?
  userAgent  String?  @db.Text
  failReason String?
  createdAt  DateTime @default(now())

  @@index([email])
  @@index([createdAt])
  @@index([success])
  @@map("auth_login_attempts")
}

//Email
model EmailLog {
  id         String      @id @default(cuid())
  userId     String?
  recipient  String
  subject    String
  body       String      @db.Text
  type       String
  status     EmailStatus
  provider   String      @default("resend")
  providerId String?     @unique

  templateId String?
  metadata   Json?

  error String? @db.Text

  sentAt    DateTime?
  openedAt  DateTime?
  clickedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([providerId])
  @@index([status])
  @@index([createdAt])
  @@map("email_log")
}

enum EmailType {
  PASSWORD_RESET
  EMAIL_VERIFICATION
  WELCOME
  NOTIFICATION
  MARKETING
}

enum EmailStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
  BOUNCED
}

model Document {
  id String @id @default(uuid())

  // Archivo
  fileName    String
  fileKey     String @unique
  contentType String
  size        Int

  status String @default("PENDING")

  checksum String?
  metadata Json?

  entityType String
  entityId   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deletedAt DateTime?
  restoreAt DateTime?

  createdBy String?
  creator   User?   @relation("CreatedDocuments", fields: [createdBy], references: [id], onDelete: SetNull)

  deletedBy String?
  deletor   User?   @relation("DeletedDocuments", fields: [deletedBy], references: [id], onDelete: SetNull)

  restoreBy String?
  restorer  User?   @relation("RestoredDocuments", fields: [restoreBy], references: [id], onDelete: SetNull)

  updatedBy String?
  updater   User?   @relation("UpdatedDocuments", fields: [updatedBy], references: [id], onDelete: SetNull)

  // Propiedad (RBAC)
  ownerId             String?
  ownerTeamId         String?
  ownerOrganizationId String?

  owner             User?         @relation("OwnedDocuments", fields: [ownerId], references: [id], onDelete: SetNull)
  ownerTeam         Team?         @relation("OwnedDocuments", fields: [ownerTeamId], references: [id], onDelete: SetNull)
  ownerOrganization Organization? @relation("OwnedDocuments", fields: [ownerOrganizationId], references: [id], onDelete: SetNull)

  // Visibilidad
  isPublic Boolean @default(false)

  @@index([entityId, entityType, status])
  @@index([fileName])
  @@index([createdAt])
  @@index([ownerId])
  @@index([ownerTeamId])
  @@index([ownerOrganizationId])
  @@map("document")
}

// Roles personalizables por organización
model Role {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  isSystem       Boolean  @default(false) // admin, viewer no se borran
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  permissions  RolePermission[]
  users        OrganizationMember[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("rbac_roles")
}

model RolePermission {
  id       String @id @default(cuid())
  roleId   String
  resource String // 'documents', 'leads', 'invoices'
  action   String // 'read', 'create', 'update', 'delete'
  scope    String @default("own") // 'all' | 'organization' | 'team' | 'own'

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, resource, action])
  @@index([roleId])
  @@index([resource])
  @@map("rbac_role_permissions")
}

// Organizaciones
model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  image     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members        OrganizationMember[]
  teams          Team[]
  roles          Role[]
  ownedDocuments Document[]           @relation("OwnedDocuments")
  ownedCompanies Company[]            @relation("OwnedCompanies")

  @@index([slug])
  @@map("org_organizations")
}

model OrganizationMember {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  roleId         String
  isActive       Boolean  @default(true)
  joinedAt       DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id])
  teamMembers  TeamMember[]

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
  @@index([roleId])
  @@map("org_members")
}

model Team {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members        TeamMember[]
  ownedDocuments Document[]   @relation("OwnedDocuments")
  ownedCompanies Company[]    @relation("OwnedCompanies")

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("org_teams")
}

model TeamMember {
  id       String @id @default(cuid())
  teamId   String
  memberId String // FK a OrganizationMember

  team   Team               @relation(fields: [teamId], references: [id], onDelete: Cascade)
  member OrganizationMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([teamId, memberId])
  @@index([teamId])
  @@index([memberId])
  @@map("org_team_members")
}

// Modelo de prueba para patrones base
model Company {
  id          String  @id @default(cuid())
  name        String
  nif         String  @unique
  sector      String?
  website     String?
  description String?
  status      String  @default("ACTIVE") // ACTIVE, TRASHED, etc.

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Auditoría
  deletedAt DateTime?
  restoreAt DateTime?

  createdBy String?
  creator   User?   @relation("CreatedCompanies", fields: [createdBy], references: [id], onDelete: SetNull)

  deletedBy String?
  deletor   User?   @relation("DeletedCompanies", fields: [deletedBy], references: [id], onDelete: SetNull)

  restoreBy String?
  restorer  User?   @relation("RestoredCompanies", fields: [restoreBy], references: [id], onDelete: SetNull)

  updatedBy String?
  updater   User?   @relation("UpdatedCompanies", fields: [updatedBy], references: [id], onDelete: SetNull)

  // Propiedad (RBAC)
  ownerId             String?
  ownerTeamId         String?
  ownerOrganizationId String?

  owner             User?         @relation("OwnedCompanies", fields: [ownerId], references: [id], onDelete: SetNull)
  ownerTeam         Team?         @relation("OwnedCompanies", fields: [ownerTeamId], references: [id], onDelete: SetNull)
  ownerOrganization Organization? @relation("OwnedCompanies", fields: [ownerOrganizationId], references: [id], onDelete: SetNull)

  @@index([nif])
  @@index([status])
  @@index([ownerId])
  @@index([ownerTeamId])
  @@index([ownerOrganizationId])
  @@map("test_companies")
}

// Acceso explícito a entidades concretas (compartir)
model EntityAccess {
  id          String   @id @default(cuid())
  userId      String
  entityName  String
  entityId    String
  accessLevel String   @default("viewer") // 'owner' | 'editor' | 'viewer'
  grantedBy   String?
  grantedAt   DateTime @default(now())

  user    User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  granter User? @relation("GrantedAccess", fields: [grantedBy], references: [id], onDelete: SetNull)

  @@unique([userId, entityName, entityId])
  @@index([userId, entityName])
  @@index([entityName, entityId])
  @@map("rbac_entity_access")
}
