datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum RecordStatus {
  ACTIVE
  PENDING
  TRASHED
  INACTIVE
  ARCHIVED
  SUSPENDED
}

// ==========================================
// AUTHENTICATION & USERS
// ==========================================

model User {
  id            String   @id @default(uuid(7))
  email         String?  @unique
  password      String?
  name          String?
  image         String?
  role          String?  @default("user")
  emailVerified Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Auditoría y Propiedad: Documentos
  createdDocuments  Document[] @relation("CreatedDocuments")
  deletedDocuments  Document[] @relation("DeletedDocuments")
  restoredDocuments Document[] @relation("RestoredDocuments")
  updatedDocuments  Document[] @relation("UpdatedDocuments")
  ownedDocuments    Document[] @relation("UserOwnedDocuments")

  // Auditoría y Propiedad: Compañías
  createdCompanies  Company[] @relation("CreatedCompanies")
  deletedCompanies  Company[] @relation("DeletedCompanies")
  restoredCompanies Company[] @relation("RestoredCompanies")
  updatedCompanies  Company[] @relation("UpdatedCompanies")
  ownedCompanies    Company[] @relation("UserOwnedCompanies")

  // Auditoría y Propiedad: Organizaciones
  createdOrganizations  Organization[] @relation("CreatedOrganizations")
  deletedOrganizations  Organization[] @relation("DeletedOrganizations")
  restoredOrganizations Organization[] @relation("RestoredOrganizations")
  updatedOrganizations  Organization[] @relation("UpdatedOrganizations")
  ownedOrganizations    Organization[] @relation("UserOwnedOrganizations")

  invitedMembers     OrganizationMember[] @relation("InvitedMembers")
  removedMembers     OrganizationMember[] @relation("RemovedMembers")
  roleUpdatedMembers OrganizationMember[] @relation("RoleUpdatedMembers")

  // Auditoría y Propiedad: Roles
  createdRoles  Role[] @relation("CreatedRoles")
  deletedRoles  Role[] @relation("DeletedRoles")
  restoredRoles Role[] @relation("RestoredRoles")
  updatedRoles  Role[] @relation("UpdatedRoles")
  ownedRoles    Role[] @relation("UserOwnedRoles")

  grantedRolePermissions RolePermission[] @relation("GrantedRolePermissions")
  revokedRolePermissions RolePermission[] @relation("RevokedRolePermissions")

  // Auditoría y Propiedad: Teams
  createdTeams  Team[] @relation("CreatedTeams")
  deletedTeams  Team[] @relation("DeletedTeams")
  restoredTeams Team[] @relation("RestoredTeams")
  updatedTeams  Team[] @relation("UpdatedTeams")

  invitedTeamMembers     TeamMember[] @relation("InvitedTeamMembers")
  removedTeamMembers     TeamMember[] @relation("RemovedTeamMembers")
  roleUpdatedTeamMembers TeamMember[] @relation("RoleUpdatedTeamMembers")

  // Auth Auxiliar
  accounts  Account[]
  sessions  Session[]
  keys      Key[]
  emailLogs EmailLog[]

  // Acceso y Membresía
  memberships   OrganizationMember[]
  entityAccess  EntityAccess[]       @relation("UserEntityAccess")
  grantedAccess EntityAccess[]       @relation("GrantedAccess")
  revokedAccess EntityAccess[]       @relation("RevokedAccess")

  @@index([email])
  @@index([isActive])
  @@map("auth_users")
}

model Account {
  id                    String    @id @default(uuid(7))
  userId                String
  providerId            String
  accountId             String
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  idToken               String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("auth_accounts")
}

model Session {
  id        String   @id @default(uuid(7))
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?  @db.Text
  isValid   Boolean  @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([token])
  @@index([isValid])
  @@map("auth_sessions")
}

model VerificationToken {
  id         String   @id @default(uuid(7))
  identifier String
  token      String   @unique
  expires    DateTime
  used       Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@unique([identifier, token])
  @@index([expires])
  @@index([used])
  @@map("auth_verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(uuid(7))
  email     String
  token     String   @unique
  expires   DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
  @@index([expires])
  @@index([used])
  @@map("auth_password_reset_tokens")
}

model EmailVerificationCode {
  id        String   @id @default(uuid(7))
  email     String
  code      String
  expires   DateTime
  attempts  Int      @default(0)
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([code])
  @@index([expires])
  @@index([used])
  @@map("auth_email_verification_codes")
}

model Verification {
  id         String    @id @default(uuid(7))
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("auth_verification")
}

model Key {
  id         String    @id @default(uuid(7))
  userId     String
  name       String?
  secret     String
  lastUsedAt DateTime?
  expiresAt  DateTime?
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
  @@map("auth_keys")
}

model LoginAttempt {
  id         String   @id @default(uuid(7))
  email      String
  success    Boolean
  ipAddress  String?
  userAgent  String?  @db.Text
  failReason String?
  createdAt  DateTime @default(now())

  @@index([email])
  @@index([createdAt])
  @@index([success])
  @@map("auth_login_attempts")
}

// ==========================================
// COMMUNICATIONS
// ==========================================

enum EmailType {
  PASSWORD_RESET
  EMAIL_VERIFICATION
  WELCOME
  NOTIFICATION
  MARKETING
}

enum EmailStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
  BOUNCED
}

model EmailLog {
  id         String      @id @default(uuid(7))
  userId     String?
  recipient  String
  subject    String
  body       String      @db.Text
  type       String
  status     EmailStatus
  provider   String      @default("resend")
  providerId String?     @unique

  templateId String?
  metadata   Json?

  error String? @db.Text

  sentAt    DateTime?
  openedAt  DateTime?
  clickedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([providerId])
  @@index([status])
  @@index([createdAt])
  @@map("email_log")
}

// ==========================================
// CORE ENTITIES & AUDIT PATTERNS
// ==========================================

model Document {
  id String @id @default(uuid(7))

  // Archivo
  fileName    String
  fileKey     String @unique
  contentType String
  size        Int

  status RecordStatus @default(PENDING)

  checksum String?
  metadata Json?

  entityType String
  entityId   String

  // Auditoría
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  restoreAt DateTime?

  createdBy String?
  creator   User?   @relation("CreatedDocuments", fields: [createdBy], references: [id], onDelete: SetNull)

  deletedBy String?
  deletor   User?   @relation("DeletedDocuments", fields: [deletedBy], references: [id], onDelete: SetNull)

  restoreBy String?
  restorer  User?   @relation("RestoredDocuments", fields: [restoreBy], references: [id], onDelete: SetNull)

  updatedBy String?
  updater   User?   @relation("UpdatedDocuments", fields: [updatedBy], references: [id], onDelete: SetNull)

  // Propiedad (RBAC)
  ownerId             String?
  ownerTeamId         String?
  ownerOrganizationId String?

  owner             User?         @relation("UserOwnedDocuments", fields: [ownerId], references: [id], onDelete: SetNull)
  ownerTeam         Team?         @relation("TeamOwnedDocuments", fields: [ownerTeamId], references: [id], onDelete: SetNull)
  ownerOrganization Organization? @relation("OrgOwnedDocuments", fields: [ownerOrganizationId], references: [id], onDelete: SetNull)

  // Visibilidad
  isPublic Boolean @default(false)

  @@index([entityId, entityType, status])
  @@index([fileName])
  @@index([createdAt])
  @@index([ownerId])
  @@index([ownerTeamId])
  @@index([ownerOrganizationId])
  @@map("document")
}

// ==========================================
// ORGANIZATION, TEAMS & ROLES
// ==========================================

model Role {
  id             String  @id @default(uuid(7))
  organizationId String
  name           String
  slug           String // "admin", "manager", "viewer"
  description    String?
  isSystem       Boolean @default(false) // admin, viewer no se borran

  status RecordStatus @default(ACTIVE)

  // Auditoría
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  restoreAt DateTime?

  createdBy String?
  creator   User?   @relation("CreatedRoles", fields: [createdBy], references: [id], onDelete: SetNull)

  deletedBy String?
  deletor   User?   @relation("DeletedRoles", fields: [deletedBy], references: [id], onDelete: SetNull)

  restoreBy String?
  restorer  User?   @relation("RestoredRoles", fields: [restoreBy], references: [id], onDelete: SetNull)

  updatedBy String?
  updater   User?   @relation("UpdatedRoles", fields: [updatedBy], references: [id], onDelete: SetNull)

  // Relaciones Estructurales
  organization Organization         @relation("OrganizationRoles", fields: [organizationId], references: [id], onDelete: Cascade)
  permissions  RolePermission[]
  users        OrganizationMember[]

  // Propiedad (RBAC)
  ownerId             String?
  ownerTeamId         String?
  ownerOrganizationId String?

  owner             User?         @relation("UserOwnedRoles", fields: [ownerId], references: [id], onDelete: SetNull)
  ownerTeam         Team?         @relation("TeamOwnedRoles", fields: [ownerTeamId], references: [id], onDelete: SetNull)
  ownerOrganization Organization? @relation("OrgOwnedRoles", fields: [ownerOrganizationId], references: [id], onDelete: SetNull)
  teamMembers       TeamMember[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@map("rbac_roles")
}

enum PermissionScope {
  ALL
  ORGANIZATION
  TEAM
  OWN
}

enum PermissionAction {
  READ
  CREATE
  UPDATE
  DELETE
  RESTORE
  EXPORT
  IMPORT
  MANAGE
}

model RolePermission {
  id       String           @id @default(uuid(7))
  roleId   String
  resource String // 'documents', 'leads', 'invoices'
  action   PermissionAction
  scope    PermissionScope  @default(OWN)
  scopeId  String?

  grantedAt DateTime @default(now())
  grantedBy String?
  granter   User?    @relation("GrantedRolePermissions", fields: [grantedBy], references: [id], onDelete: SetNull)
  revokedBy String?
  revoker   User?    @relation("RevokedRolePermissions", fields: [revokedBy], references: [id], onDelete: SetNull)

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, resource, action])
  @@index([roleId])
  @@index([resource])
  @@map("rbac_role_permissions")
}

model Organization {
  id     String       @id @default(uuid(7))
  name   String
  slug   String       @unique
  image  String?
  status RecordStatus @default(ACTIVE)

  // Auditoría
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  restoreAt DateTime?

  createdBy String?
  creator   User?   @relation("CreatedOrganizations", fields: [createdBy], references: [id], onDelete: SetNull)

  deletedBy String?
  deletor   User?   @relation("DeletedOrganizations", fields: [deletedBy], references: [id], onDelete: SetNull)

  restoreBy String?
  restorer  User?   @relation("RestoredOrganizations", fields: [restoreBy], references: [id], onDelete: SetNull)

  updatedBy String?
  updater   User?   @relation("UpdatedOrganizations", fields: [updatedBy], references: [id], onDelete: SetNull)

  // Propiedad (RBAC) - Soporte para sub-organizaciones
  ownerId             String?
  ownerTeamId         String?
  ownerOrganizationId String?

  owner             User?         @relation("UserOwnedOrganizations", fields: [ownerId], references: [id], onDelete: SetNull)
  ownerTeam         Team?         @relation("TeamOwnedOrganizations", fields: [ownerTeamId], references: [id], onDelete: SetNull)
  ownerOrganization Organization? @relation("OrgOwnedOrganizations", fields: [ownerOrganizationId], references: [id], onDelete: SetNull)

  // Relaciones Estructurales
  members OrganizationMember[]
  teams   Team[]
  roles   Role[]               @relation("OrganizationRoles")

  // Elementos que posee esta organización (Reverse RBAC)
  ownedDocuments     Document[]     @relation("OrgOwnedDocuments")
  ownedCompanies     Company[]      @relation("OrgOwnedCompanies")
  ownedRoles         Role[]         @relation("OrgOwnedRoles")
  ownedOrganizations Organization[] @relation("OrgOwnedOrganizations")

  @@index([slug])
  @@map("org_organizations")
}

model OrganizationMember {
  id             String   @id @default(uuid(7))
  userId         String
  organizationId String
  roleId         String
  isActive       Boolean  @default(true)
  joinedAt       DateTime @default(now())
  updatedAt      DateTime @updatedAt

  invitedBy     String?
  inviter       User?   @relation("InvitedMembers", fields: [invitedBy], references: [id], onDelete: SetNull)
  removedBy     String?
  remover       User?   @relation("RemovedMembers", fields: [removedBy], references: [id], onDelete: SetNull)
  roleUpdatedBy String?
  roleUpdater   User?   @relation("RoleUpdatedMembers", fields: [roleUpdatedBy], references: [id], onDelete: SetNull)

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id])
  teamMembers  TeamMember[]

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
  @@index([roleId])
  @@map("org_members")
}

model Team {
  id             String       @id @default(uuid(7))
  organizationId String
  name           String
  description    String?
  status         RecordStatus @default(ACTIVE)

  // Auditoría
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  restoreAt DateTime?

  createdBy String?
  creator   User?   @relation("CreatedTeams", fields: [createdBy], references: [id], onDelete: SetNull)

  deletedBy String?
  deletor   User?   @relation("DeletedTeams", fields: [deletedBy], references: [id], onDelete: SetNull)

  restoreBy String?
  restorer  User?   @relation("RestoredTeams", fields: [restoreBy], references: [id], onDelete: SetNull)

  updatedBy String?
  updater   User?   @relation("UpdatedTeams", fields: [updatedBy], references: [id], onDelete: SetNull)

  // Relaciones
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members      TeamMember[]

  // Elementos que posee este equipo
  ownedDocuments     Document[]     @relation("TeamOwnedDocuments")
  ownedCompanies     Company[]      @relation("TeamOwnedCompanies")
  ownedRoles         Role[]         @relation("TeamOwnedRoles")
  ownedOrganizations Organization[] @relation("TeamOwnedOrganizations")

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("org_teams")
}

model TeamMember {
  id       String @id @default(uuid(7))
  teamId   String
  memberId String
  roleId   String

  joinedAt DateTime @default(now())

  // Auditoría añadida
  invitedBy String?
  inviter   User?   @relation("InvitedTeamMembers", fields: [invitedBy], references: [id], onDelete: SetNull)

  removedBy String?
  remover   User?   @relation("RemovedTeamMembers", fields: [removedBy], references: [id], onDelete: SetNull)

  roleUpdatedBy String?
  roleUpdater   User?   @relation("RoleUpdatedTeamMembers", fields: [roleUpdatedBy], references: [id], onDelete: SetNull)

  team   Team               @relation(fields: [teamId], references: [id], onDelete: Cascade)
  member OrganizationMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  role   Role               @relation(fields: [roleId], references: [id])

  @@unique([teamId, memberId])
  @@index([teamId])
  @@index([memberId])
  @@index([roleId])
  @@map("org_team_members")
}

enum EntityAccessLevel {
  OWNER
  EDITOR
  VIEWER
}

// Acceso explícito a entidades concretas (compartir)
model EntityAccess {
  id          String            @id @default(uuid(7))
  userId      String
  entityName  String
  entityId    String
  accessLevel EntityAccessLevel @default(VIEWER)
  grantedBy   String?
  grantedAt   DateTime          @default(now())
  expiresAt   DateTime?
  revokedAt   DateTime?
  revokedBy   String?

  user    User  @relation("UserEntityAccess", fields: [userId], references: [id], onDelete: Cascade)
  granter User? @relation("GrantedAccess", fields: [grantedBy], references: [id], onDelete: SetNull)
  revoker User? @relation("RevokedAccess", fields: [revokedBy], references: [id], onDelete: SetNull)

  @@unique([userId, entityName, entityId])
  @@index([expiresAt])
  @@index([userId, entityName])
  @@index([entityName, entityId])
  @@map("rbac_entity_access")
}

// ==========================================
// ENTIDADES DE NEGOCIO
// ==========================================

// Modelo de prueba para patrones base
model Company {
  id          String       @id @default(uuid(7))
  name        String
  nif         String       @unique
  sector      String?
  website     String?
  description String?
  status      RecordStatus @default(ACTIVE)

  // Auditoría
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  restoreAt DateTime?

  createdBy String?
  creator   User?   @relation("CreatedCompanies", fields: [createdBy], references: [id], onDelete: SetNull)

  deletedBy String?
  deletor   User?   @relation("DeletedCompanies", fields: [deletedBy], references: [id], onDelete: SetNull)

  restoreBy String?
  restorer  User?   @relation("RestoredCompanies", fields: [restoreBy], references: [id], onDelete: SetNull)

  updatedBy String?
  updater   User?   @relation("UpdatedCompanies", fields: [updatedBy], references: [id], onDelete: SetNull)

  // Propiedad (RBAC)
  ownerId             String?
  ownerTeamId         String?
  ownerOrganizationId String?

  owner             User?         @relation("UserOwnedCompanies", fields: [ownerId], references: [id], onDelete: SetNull)
  ownerTeam         Team?         @relation("TeamOwnedCompanies", fields: [ownerTeamId], references: [id], onDelete: SetNull)
  ownerOrganization Organization? @relation("OrgOwnedCompanies", fields: [ownerOrganizationId], references: [id], onDelete: SetNull)

  @@index([nif])
  @@index([status])
  @@index([ownerId])
  @@index([ownerTeamId])
  @@index([ownerOrganizationId])
  @@map("test_companies")
}
