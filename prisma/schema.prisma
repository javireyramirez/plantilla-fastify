datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum RecordStatus {
  ACTIVE
  PENDING
  TRASHED
  INACTIVE
  ARCHIVED
  SUSPENDED
}

// ==========================================
// AUTHENTICATION & USERS
// ==========================================

model User {
  id            String   @id @default(uuid(7))
  email         String?  @unique
  password      String?
  name          String?
  image         String?
  emailVerified Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  isSystem      Boolean  @default(false)
  isSuperAdmin  Boolean  @default(false)

  // Auditoría
  status     RecordStatus @default(ACTIVE)
  deletedAt  DateTime?
  restoredAt DateTime?
  createdBy  String?
  deletedBy  String?
  restoredBy String?
  updatedBy  String?

  // Auditoría y Propiedad: Documentos
  createdDocuments  Document[] @relation("CreatedDocuments")
  deletedDocuments  Document[] @relation("DeletedDocuments")
  restoredDocuments Document[] @relation("RestoredDocuments")
  updatedDocuments  Document[] @relation("UpdatedDocuments")

  // Auditoría y Propiedad: Compañías
  createdCompanies  Company[] @relation("CreatedCompanies")
  deletedCompanies  Company[] @relation("DeletedCompanies")
  restoredCompanies Company[] @relation("RestoredCompanies")
  updatedCompanies  Company[] @relation("UpdatedCompanies")
  ownedCompanies    Company[] @relation("UserOwnedCompanies")

  // Auditoría y Propiedad: Roles
  createdRoles  Role[] @relation("CreatedRoles")
  deletedRoles  Role[] @relation("DeletedRoles")
  restoredRoles Role[] @relation("RestoredRoles")
  updatedRoles  Role[] @relation("UpdatedRoles")

  grantedRolePermissions RolePermission[] @relation("GrantedRolePermissions")
  updatedRolePermissions RolePermission[] @relation("UpdatedRolePermissions")

  // Auditoría y Propiedad: Teams
  createdTeams  Team[] @relation("CreatedTeams")
  deletedTeams  Team[] @relation("DeletedTeams")
  restoredTeams Team[] @relation("RestoredTeams")
  updatedTeams  Team[] @relation("UpdatedTeams")

  invitedTeamUsers TeamUser[] @relation("InvitedTeamUsers")
  teamUser         TeamUser[] @relation("TeamUser")

  // Auth Auxiliar
  accounts  Account[]
  sessions  Session[]
  keys      Key[]
  emailLogs EmailLog[]

  // Asignaciones de roles
  roleAssignments    RoleAssignment[] @relation("UserAssignments")
  grantedAssignments RoleAssignment[] @relation("GrantedAssignments")
  // rolePermissionAuditLogs RolePermissionAuditLog[]

  //Modules
  createdModule  Module[] @relation("CreatedModule")
  deletedModule  Module[] @relation("DeletedModule")
  restoredModule Module[] @relation("RestoredModule")
  updatedModule  Module[] @relation("UpdatedModule")

  // Papelera y Auditoría
  auditLogs      AuditLog[] @relation("UserAuditLogs")
  trashDeletions TrashBin[] @relation("TrashDeletions")

  @@index([email])
  @@index([isActive])
  @@map("auth_users")
}

model Account {
  id                    String    @id @default(uuid(7))
  userId                String
  providerId            String
  accountId             String
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  idToken               String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("auth_accounts")
}

model Session {
  id        String   @id @default(uuid(7))
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?  @db.Text
  isValid   Boolean  @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([token])
  @@index([isValid])
  @@map("auth_sessions")
}

model VerificationToken {
  id         String   @id @default(uuid(7))
  identifier String
  token      String   @unique
  expires    DateTime
  used       Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@unique([identifier, token])
  @@index([expires])
  @@index([used])
  @@map("auth_verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(uuid(7))
  email     String
  token     String   @unique
  expires   DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
  @@index([expires])
  @@index([used])
  @@map("auth_password_reset_tokens")
}

model EmailVerificationCode {
  id        String   @id @default(uuid(7))
  email     String
  code      String
  expires   DateTime
  attempts  Int      @default(0)
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([code])
  @@index([expires])
  @@index([used])
  @@map("auth_email_verification_codes")
}

model Verification {
  id         String    @id @default(uuid(7))
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("auth_verifications")
}

model Key {
  id         String    @id @default(uuid(7))
  userId     String
  name       String?
  secret     String
  lastUsedAt DateTime?
  expiresAt  DateTime?
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
  @@map("auth_keys")
}

model LoginAttempt {
  id         String   @id @default(uuid(7))
  email      String
  success    Boolean
  ipAddress  String?
  userAgent  String?  @db.Text
  failReason String?
  createdAt  DateTime @default(now())

  @@index([email])
  @@index([createdAt])
  @@index([success])
  @@map("auth_login_attempts")
}

// ==========================================
// COMMUNICATIONS
// ==========================================

enum EmailType {
  PASSWORD_RESET
  EMAIL_VERIFICATION
  WELCOME
  NOTIFICATION
  MARKETING
}

enum EmailStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
  BOUNCED
}

model EmailLog {
  id         String      @id @default(uuid(7))
  userId     String?
  recipient  String
  subject    String
  body       String      @db.Text
  type       String
  status     EmailStatus
  provider   String      @default("resend")
  providerId String?     @unique

  templateId String?
  metadata   Json?

  error String? @db.Text

  sentAt    DateTime?
  openedAt  DateTime?
  clickedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([providerId])
  @@index([status])
  @@index([createdAt])
  @@map("email_logs")
}

// ==========================================
// CORE ENTITIES & AUDIT PATTERNS
// ==========================================

model Document {
  id String @id @default(uuid(7))

  // Archivo
  fileName    String
  fileKey     String @unique
  contentType String
  size        Int

  status RecordStatus @default(PENDING)

  checksum String?
  metadata Json?

  entityType String
  entityId   String

  // Auditoría
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  restoredAt DateTime?

  createdBy String?
  creator   User?   @relation("CreatedDocuments", fields: [createdBy], references: [id], onDelete: SetNull)

  deletedBy String?
  deletor   User?   @relation("DeletedDocuments", fields: [deletedBy], references: [id], onDelete: SetNull)

  restoredBy String?
  restorer   User?   @relation("RestoredDocuments", fields: [restoredBy], references: [id], onDelete: SetNull)

  updatedBy String?
  updater   User?   @relation("UpdatedDocuments", fields: [updatedBy], references: [id], onDelete: SetNull)

  // Visibilidad
  isPublic Boolean @default(false)

  @@index([entityId, entityType, status])
  @@index([fileName])
  @@index([createdAt])
  @@map("documents")
}

// ==========================================
// RBAC: MÓDULOS
// ==========================================

model Module {
  id                 String       @id @default(uuid(7))
  name               String
  slug               String       @unique
  description        String?
  icon               String?
  isActive           Boolean      @default(true)
  sortOrder          Int          @default(0)
  defaultPermissions Json?
  status             RecordStatus @default(ACTIVE)

  // Auditoría Unificada
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  restoredAt DateTime?

  createdBy String?
  creator   User?   @relation("CreatedModule", fields: [createdBy], references: [id], onDelete: SetNull)

  deletedBy String?
  deletor   User?   @relation("DeletedModule", fields: [deletedBy], references: [id], onDelete: SetNull)

  restoredBy String?
  restorer   User?   @relation("RestoredModule", fields: [restoredBy], references: [id], onDelete: SetNull)

  updatedBy String?
  updater   User?   @relation("UpdatedModule", fields: [updatedBy], references: [id], onDelete: SetNull)

  permissions RolePermission[]

  // Papelera y Auditoría
  auditLogs  AuditLog[] @relation("ModuleAuditLogs")
  trashItems TrashBin[] @relation("ModuleTrashItems")

  @@map("rbac_modules")
}

// ==========================================
// RBAC: ROLES Y PERMISOS
// ==========================================

model Role {
  id          String  @id @default(uuid(7))
  name        String  @unique
  slug        String  @unique
  description String?
  color       String?
  icon        String?
  isSystem    Boolean @default(false)

  status RecordStatus @default(ACTIVE)

  // Auditoría
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  restoredAt DateTime?

  createdBy String?
  creator   User?   @relation("CreatedRoles", fields: [createdBy], references: [id], onDelete: SetNull)

  deletedBy String?
  deletor   User?   @relation("DeletedRoles", fields: [deletedBy], references: [id], onDelete: SetNull)

  restoredBy String?
  restorer   User?   @relation("RestoredRoles", fields: [restoredBy], references: [id], onDelete: SetNull)

  updatedBy String?
  updater   User?   @relation("UpdatedRoles", fields: [updatedBy], references: [id], onDelete: SetNull)

  // Relaciones
  permissions     RolePermission[]
  roleAssignments RoleAssignment[]

  @@index([name])
  @@index([isSystem])
  @@map("rbac_roles")
}

enum PermissionScope {
  GLOBAL
  TEAM
  OWN
}

enum PermissionAction {
  READ
  CREATE
  UPDATE
  DELETE
  RESTORE
  EXPORT
  IMPORT
  SETTINGS
}

model RolePermission {
  id       String           @id @default(uuid(7))
  roleId   String
  moduleId String
  action   PermissionAction
  scope    PermissionScope  @default(OWN)

  grantedAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  grantedBy String?
  granter   User?   @relation("GrantedRolePermissions", fields: [grantedBy], references: [id], onDelete: SetNull)
  updatedBy String?
  updater   User?   @relation("UpdatedRolePermissions", fields: [updatedBy], references: [id], onDelete: SetNull)

  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([roleId, moduleId, action])
  @@index([roleId])
  @@index([moduleId])
  @@map("rbac_role_permissions")
}

enum PrincipalType {
  USER
  TEAM
}

model RoleAssignment {
  id     String @id @default(uuid(7))
  roleId String

  userId String?
  teamId String?

  assignedAt DateTime @default(now())
  assignedBy String?

  role    Role  @relation(fields: [roleId], references: [id], onDelete: Cascade)
  granter User? @relation("GrantedAssignments", fields: [assignedBy], references: [id], onDelete: SetNull)

  assignedUser User? @relation("UserAssignments", fields: [userId], references: [id], onDelete: Cascade)
  assignedTeam Team? @relation("TeamAssignments", fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([roleId, userId])
  @@unique([roleId, teamId])
  @@index([userId])
  @@index([teamId])
  @@map("rbac_role_assignments")
}

// ==========================================
//  TEAMS & MEMBERS
// ==========================================

model Team {
  id          String       @id @default(uuid(7))
  name        String       @unique
  slug        String       @unique
  description String?
  status      RecordStatus @default(ACTIVE)

  // Auditoría
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  restoredAt DateTime?

  createdBy String?
  creator   User?   @relation("CreatedTeams", fields: [createdBy], references: [id], onDelete: SetNull)

  deletedBy String?
  deletor   User?   @relation("DeletedTeams", fields: [deletedBy], references: [id], onDelete: SetNull)

  restoredBy String?
  restorer   User?   @relation("RestoredTeams", fields: [restoredBy], references: [id], onDelete: SetNull)

  updatedBy String?
  updater   User?   @relation("UpdatedTeams", fields: [updatedBy], references: [id], onDelete: SetNull)

  // Relaciones
  users TeamUser[]

  // Elementos que posee este team
  roleAssignments RoleAssignment[] @relation("TeamAssignments")

  @@map("teams")
}

model TeamUser {
  id     String @id @default(uuid(7))
  teamId String
  userId String

  joinedAt  DateTime @default(now())
  invitedBy String?

  inviter User? @relation("InvitedTeamUsers", fields: [invitedBy], references: [id], onDelete: SetNull)
  user    User  @relation("TeamUser", fields: [userId], references: [id], onDelete: Cascade)

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
  @@map("team_users")
}

// ==========================================
// ENTIDADES DE NEGOCIO
// ==========================================
//

model Company {
  id          String       @id @default(uuid(7))
  name        String
  nif         String       @unique
  sector      String?
  website     String?
  description String?
  status      RecordStatus @default(ACTIVE)

  // Auditoría
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  restoredAt DateTime?

  createdBy String?
  creator   User?   @relation("CreatedCompanies", fields: [createdBy], references: [id], onDelete: SetNull)

  deletedBy String?
  deletor   User?   @relation("DeletedCompanies", fields: [deletedBy], references: [id], onDelete: SetNull)

  restoredBy String?
  restorer   User?   @relation("RestoredCompanies", fields: [restoredBy], references: [id], onDelete: SetNull)

  updatedBy String?
  updater   User?   @relation("UpdatedCompanies", fields: [updatedBy], references: [id], onDelete: SetNull)

  // Propiedad (RBAC)
  ownerId String?

  owner User? @relation("UserOwnedCompanies", fields: [ownerId], references: [id], onDelete: SetNull)

  @@index([nif])
  @@index([status])
  @@index([ownerId])
  @@map("companies")
}

// ==========================================
// UNIFIED TRASH & AUDITING MODELS
// ==========================================

model AuditLog {
  id          String      @id @default(uuid(7))
  userId      String?
  action      AuditAction
  
  // Module reference (Option C)
  moduleId    String?
  moduleSlug  String?
  module      Module?     @relation("ModuleAuditLogs", fields: [moduleId], references: [id], onDelete: SetNull)
  
  entityId    String?
  displayName String?
  description String?     @db.Text
  metadata    Json?
  ipAddress   String?
  userAgent   String?     @db.Text
  createdAt   DateTime    @default(now())

  user        User?       @relation("UserAuditLogs", fields: [userId], references: [id], onDelete: SetNull)

  @@index([action])
  @@index([moduleSlug, entityId])
  @@index([createdAt])
  @@map("sys_audit_logs")
}

model TrashBin {
  id          String   @id @default(uuid(7))
  
  // Module reference (Option C)
  moduleId    String
  moduleSlug  String
  module      Module   @relation("ModuleTrashItems", fields: [moduleId], references: [id], onDelete: Cascade)
  
  entityId    String   // The UUID of the soft-deleted row
  displayName String   // Quick preview to show the user (e.g. name, file name)
  deletedAt   DateTime @default(now())
  deletedBy   String?
  expiresAt   DateTime // Date when this item will be permanently purged
  metadata    Json?    // Optional extra context

  // Ownership mirrors (for RBAC)
  ownerId     String?
  createdBy   String?

  deletor     User?    @relation("TrashDeletions", fields: [deletedBy], references: [id], onDelete: SetNull)

  @@unique([moduleSlug, entityId])
  @@index([expiresAt])
  @@index([deletedAt])
  @@map("sys_trash_bin")
}

enum AuditAction {
  CREATE
  UPDATE
  SOFT_DELETE
  RESTORE
  HARD_DELETE
  LOGIN
  LOGOUT
}

